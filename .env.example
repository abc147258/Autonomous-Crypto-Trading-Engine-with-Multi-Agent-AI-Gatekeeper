# ============================================================
# .env.example — Copy เป็น .env แล้วใส่ค่าจริง
# ห้าม commit .env ขึ้น GitHub เด็ดขาด!
# ============================================================

# --- Binance API ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TH_BASE_URL=https://api.binance.com
USE_TESTNET=False

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Email (Gmail App Password) ---
EMAIL_SENDER=your@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECEIVER=your@gmail.com

# --- Whale Alert (optional) ---
WHALE_ALERT_API_KEY=

# --- Trading ---
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,ADAUSDT,DOGEUSDT,XRPUSDT
TAKE_PROFIT_PCT=8.0
STOP_LOSS_PCT=4.0
MAX_OPEN_TRADES=7
MIN_BUY_CONFIDENCE=65
MIN_SELL_CONFIDENCE=60
CANDLE_INTERVAL=4h
CANDLE_LIMIT=100
SCAN_INTERVAL_SECONDS=900

# --- Risk Management ---
PORTFOLIO_STOP_LOSS_PCT=15.0
LIMIT_ORDER_SLIPPAGE_PCT=0.1
LIMIT_ORDER_TIMEOUT_S=30
MAX_DAILY_LOSS_PCT=5.0

# --- Signal Thresholds ---
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
FEAR_GREED_BUY=25
FEAR_GREED_SELL=75
DEAD_VOL_CONFIDENCE_THRESHOLD=35
EXTREME_FEAR_THRESHOLD=15
AI_BEARISH_THRESHOLD=-50
BUY_SIGNAL_MIN_CONFIDENCE=60

# --- Notifier Schedule ---
FULL_CHECK_HOURS=08:00,16:00,00:00
